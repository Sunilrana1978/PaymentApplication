# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# DynamoDB table names (auto-set in Lambda via CloudFormation env vars)
IDEMPOTENCY_CACHE_TABLE=payment-idempotency-cache-production
TRANSACTIONS_TABLE=payment-transactions-production
PAYMENT_LOGS_TABLE=payment-logs-production

# AWS (only needed for local dev; Lambda uses its execution role automatically)
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# Set this to use DynamoDB Local instead of AWS DynamoDB (local dev)
# DYNAMODB_ENDPOINT=http://localhost:8000

# Local server
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
